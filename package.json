    "extend": "^3.0.2",
    "jquery": "^4.0.0",
    "jquery-ui": "^1.14.1",
    "multer": "^2.2.0",
    "node-ssdp": "^4.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/extend": "^3.0.4",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=20.0.0"
  }
